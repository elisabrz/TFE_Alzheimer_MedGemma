# ═══════════════════════════════════════════════════════════════════════════
# TFE Elisa — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════════
# Copier ce fichier en `.env` et renseigner les valeurs :
#   cp .env.example .env
#
# Ne jamais committer le `.env` (il est dans le .gitignore).
# ═══════════════════════════════════════════════════════════════════════════

# ---- Hugging Face ----
# Token d'accès HF. MedGemma est un modèle "gated" : il faut avoir accepté les
# conditions d'utilisation sur https://huggingface.co/google/medgemma-1.5-4b-it
# puis créer un token lecture sur https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optionnel) Cache HF local pour éviter les re-téléchargements
# HF_HOME=/home/elisa/.cache/huggingface

# ---- Weights & Biases (logging d'entraînement) ----
# Créer un compte sur https://wandb.ai puis récupérer la clé API sur
# https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=tfe-alzheimer-medgemma
WANDB_ENTITY=          # laisser vide pour compte perso, sinon nom de l'org

# Désactiver wandb pour un run donné :
# WANDB_MODE=disabled

# ---- Chemins projet ----
# Racine des données brutes (IRM .npy + CSV cliniques)
DATA_ROOT=/home/elisa/data

# Dossier splits généré par 00_prepare_splits/prepare_splits.py
# (par défaut relatif au projet : ./data/splits/)
SPLITS_DIR=./data/splits

# Racine des résultats (checkpoints, figures, métriques)
RESULTS_ROOT=./results

# Chemin vers les données hôpital externe (Tâche 7) — à compléter le moment venu
# HOSPITAL_DATA=/home/elisa/data/hospital_external

# ---- CUDA / Performance (optionnel) ----
# CUDA_VISIBLE_DEVICES=0
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:256
# TOKENIZERS_PARALLELISM=false
